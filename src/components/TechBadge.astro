---
interface Props {
	label: string;
}
const { label } = Astro.props;
---

<span class="tech-badge">{label}</span>

<style>
	.tech-badge {
		display: inline-block;
		padding: 0.22em 0.65em;
		font-size: 0.78rem;
		line-height: 1.4;
		color: rgb(var(--gray-dark));
		background: rgba(var(--accent-rgb), 0.07);
		border: 1px solid var(--border);
		border-radius: 999px;
		white-space: nowrap;
	}
</style>
